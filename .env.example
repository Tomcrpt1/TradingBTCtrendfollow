# Core
BOT_MODE=paper
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
SYMBOL=BTC

# Wallet / signing (required in live mode)
HYPERLIQUID_SECRET_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=

# Strategy
DONCHIAN_LEN=20
EMA_LEN=200
EMA_SLOPE_LOOKBACK=20
RSI_LEN=14
RSI_LONG_MIN=55
RSI_SHORT_MAX=45
ADX_LEN=14
ADX_MIN=20
ATR_LEN=14
TRAIL_ATR_MULT=3.0

# Volatility filter
VOL_FILTER_ENABLED=true
VOL_LOOKBACK=120
VOL_MAX_PCT=95

# Risk
RISK_PER_TRADE_PCT=2.0
USE_FIXED_NOTIONAL=false
FIXED_NOTIONAL_USD=500
MAX_LEVERAGE=3.0
MIN_ORDER_SIZE=0.001
SIZE_STEP=0.001

# Runtime
POLL_INTERVAL_SEC=15
LOG_LEVEL=INFO
STATE_PATH=state.json
LOG_PATH=logs/bot.log
USE_EXCHANGE_STOP=true
RETRY_COUNT=3
RETRY_BACKOFF_SEC=1.5
